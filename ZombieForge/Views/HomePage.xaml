<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ZombieForge.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="32 24" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Uid="HomeTitle" Style="{StaticResource TitleTextBlockStyle}"/>

        <!-- Timers -->
        <StackPanel Grid.Row="1" Spacing="8">
            <TextBlock x:Uid="TimersHeader" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <Grid ColumnSpacing="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Uid="GameTimeLabel" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.GameTimer, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}" FontFamily="Consolas"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock x:Uid="RoundTimeLabel" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.RoundTimer, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}" FontFamily="Consolas"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Player Stats -->
        <StackPanel Grid.Row="2" Spacing="8">
            <TextBlock x:Uid="PlayerStatsHeader" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Uid="PointsLabel" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.Points, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock x:Uid="KillsLabel" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.Kills, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock x:Uid="DownsLabel" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.Downs, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock x:Uid="HeadshotsLabel" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.Headshots, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Game Event Log -->
        <StackPanel Grid.Row="3" Spacing="8">
            <TextBlock x:Uid="GameEventsHeader" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <ListView ItemsSource="{x:Bind ViewModel.EventLog, Mode=OneWay}"
                      MaxHeight="300"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <TextBlock Text="{x:Bind}" Style="{StaticResource CaptionTextBlockStyle}" FontFamily="Consolas"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Grid>
</Page>
