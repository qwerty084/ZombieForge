<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ZombieForge.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="32 24" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Home" Style="{StaticResource TitleTextBlockStyle}"/>

        <!-- Player Stats -->
        <StackPanel Grid.Row="1" Spacing="8">
            <TextBlock Text="Player Stats" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Points" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.Points, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Kills" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.Kills, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Downs" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.Downs, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="Headshots" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.Headshots, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Game Event Log -->
        <StackPanel Grid.Row="2" Spacing="8">
            <TextBlock Text="Game Events" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <ListView ItemsSource="{x:Bind ViewModel.EventLog, Mode=OneWay}"
                      MaxHeight="300"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <TextBlock Text="{x:Bind}" Style="{StaticResource CaptionTextBlockStyle}" FontFamily="Consolas"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Grid>
</Page>
