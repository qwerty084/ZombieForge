<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ZombieForge.Views.ConfigPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:ZombieForge.Models"
    xmlns:converters="using:ZombieForge.Converters">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

    <ScrollViewer Grid.Row="0">
        <StackPanel Padding="32 24 32 12" Spacing="24" MaxWidth="860">

            <TextBlock x:Uid="ConfigTitle" Style="{StaticResource TitleTextBlockStyle}"/>

            <!-- Compact config file path row (found) -->
            <Border Padding="10 8" CornerRadius="6"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Visibility="{x:Bind ViewModel.ConfigFound, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE73E;" FontSize="13"
                              Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                              VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{x:Bind ViewModel.ConfigPath, Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               FontFamily="Consolas"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <Button Grid.Column="2"
                            x:Uid="ConfigOpenFolderBtn"
                            Command="{x:Bind ViewModel.OpenFolderCommand}"
                            Padding="8 3"/>
                </Grid>
            </Border>

            <!-- Compact config file not found row -->
            <Border Padding="10 8" CornerRadius="6"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}"
                    BorderThickness="1"
                    Visibility="{x:Bind ViewModel.ConfigNotFound, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE7BA;" FontSize="13"
                              Foreground="{ThemeResource SystemFillColorCautionBrush}"
                              VerticalAlignment="Center"/>
                    <TextBlock x:Uid="ConfigNotFoundText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource SystemFillColorCautionBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- COMMON SETTINGS -->
            <TextBlock x:Uid="ConfigCommonSettingsHeader" Style="{StaticResource SubtitleTextBlockStyle}"/>

            <Grid ColumnSpacing="32" RowSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- FOV -->
                <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Uid="ConfigFovLabel" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Text="cg_fov_default" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontFamily="Consolas"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Slider x:Name="FovSlider"
                            Minimum="50" Maximum="120" StepFrequency="1" TickFrequency="10"
                            TickPlacement="Outside"
                            Value="{x:Bind ViewModel.Fov, Mode=TwoWay}"
                            Width="260"/>
                    <TextBlock Text="{x:Bind FovSlider.Value, Mode=OneWay}"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               VerticalAlignment="Center" MinWidth="32"/>
                </StackPanel>

                <!-- Max FPS -->
                <StackPanel Grid.Row="1" Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Uid="ConfigMaxFpsLabel" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Text="com_maxfps" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontFamily="Consolas"/>
                </StackPanel>
                <NumberBox Grid.Row="1" Grid.Column="1"
                           Minimum="1" Maximum="1000" SpinButtonPlacementMode="Inline"
                           SmallChange="1" LargeChange="60"
                           Value="{x:Bind ViewModel.MaxFps, Mode=TwoWay}"
                           Width="160" HorizontalAlignment="Left"/>

                <!-- Sensitivity -->
                <StackPanel Grid.Row="2" Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Uid="ConfigSensitivityLabel" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Text="sensitivity" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontFamily="Consolas"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Slider x:Name="SenSlider"
                            Minimum="0.5" Maximum="30" StepFrequency="0.5" TickFrequency="5"
                            TickPlacement="Outside"
                            Value="{x:Bind ViewModel.Sensitivity, Mode=TwoWay}"
                            Width="260"/>
                    <TextBlock Text="{x:Bind SenSlider.Value, Mode=OneWay}"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               VerticalAlignment="Center" MinWidth="32"/>
                </StackPanel>

                <!-- Fullscreen -->
                <StackPanel Grid.Row="3" Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Uid="ConfigFullscreenLabel" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Text="r_fullscreen" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontFamily="Consolas"/>
                </StackPanel>
                <ToggleSwitch Grid.Row="3" Grid.Column="1"
                              x:Uid="ConfigFullscreenToggle"
                              IsOn="{x:Bind ViewModel.Fullscreen, Mode=TwoWay}"
                              HorizontalAlignment="Left"/>

                <!-- Resolution -->
                <StackPanel Grid.Row="4" Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Uid="ConfigResolutionLabel" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Text="r_mode" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontFamily="Consolas"/>
                </StackPanel>
                <ComboBox Grid.Row="4" Grid.Column="1"
                          ItemsSource="{x:Bind ViewModel.Resolutions}"
                          SelectedItem="{x:Bind ViewModel.Resolution, Mode=TwoWay}"
                          Width="200" HorizontalAlignment="Left"/>

                <!-- Aspect Ratio -->
                <StackPanel Grid.Row="5" Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Uid="ConfigAspectRatioLabel" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Text="r_aspectRatio" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontFamily="Consolas"/>
                </StackPanel>
                <ComboBox Grid.Row="5" Grid.Column="1"
                          ItemsSource="{x:Bind ViewModel.AspectRatios}"
                          SelectedItem="{x:Bind ViewModel.AspectRatio, Mode=TwoWay}"
                          Width="200" HorizontalAlignment="Left"/>
            </Grid>

            <!-- KEY BINDINGS -->
            <TextBlock x:Uid="ConfigKeyBindingsHeader" Style="{StaticResource SubtitleTextBlockStyle}"/>

            <!-- Preset Commands -->
            <Expander x:Uid="ConfigPresetsExpander" IsExpanded="False"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <StackPanel Spacing="12" Margin="0 8 0 0">
                    <TextBlock x:Uid="ConfigPresetsHint"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <ListView x:Name="PresetsList"
                              ItemsSource="{x:Bind ViewModel.Presets}"
                              SelectionMode="Single"
                              MaxHeight="260">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:PresetCommand">
                                <Grid Padding="0 4" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="4" Padding="6 2" HorizontalAlignment="Left">
                                        <TextBlock Text="{x:Bind Category}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{x:Bind Label}"
                                               Style="{StaticResource BodyTextBlockStyle}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{x:Bind Command}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               FontFamily="Consolas"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Key picker + Bind button -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ComboBox x:Name="PresetKeyCombo"
                                  x:Uid="ConfigPresetKeyCombo"
                                  ItemsSource="{x:Bind ViewModel.BindableKeys}"
                                  Width="140"/>
                        <Button x:Uid="ConfigBindToKeyBtn" Click="BindPreset_Click"
                                Style="{StaticResource AccentButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Expander>

            <!-- Current Binds -->
            <Expander x:Uid="ConfigCurrentBindsExpander" IsExpanded="False"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <StackPanel Spacing="8" Margin="0 8 0 0">
                    <ListView ItemsSource="{x:Bind ViewModel.CurrentBinds}"
                              SelectionMode="None"
                              IsItemClickEnabled="False"
                              MaxHeight="300">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:BindEntry">
                                <Grid Padding="0 2 12 2" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                                            CornerRadius="4" Padding="6 2" HorizontalAlignment="Left"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Key, Mode=OneWay}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="White" FontFamily="Consolas"/>
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind Command, Mode=OneWay}"
                                               Style="{StaticResource BodyTextBlockStyle}"
                                               FontFamily="Consolas"
                                               VerticalAlignment="Center"
                                               TextWrapping="NoWrap"/>
                                    <Button Grid.Column="2"
                                            Content="&#xE70F;"
                                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                                            Tag="{x:Bind}"
                                            Click="EditBindButton_Click"
                                            ToolTipService.ToolTip="Edit command"
                                            AutomationProperties.Name="Edit command"
                                            Padding="7"/>
                                    <Button Grid.Column="3"
                                            Content="&#xE74D;"
                                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                                            Tag="{x:Bind}"
                                            Click="RemoveBindButton_Click"
                                            ToolTipService.ToolTip="Remove bind"
                                            AutomationProperties.Name="Remove bind"
                                            Padding="7"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Button x:Uid="ConfigAddCustomBindBtn" Click="AddCustomBind_Click"/>
                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>

        <!-- Always-visible Save bar -->
        <Border Grid.Row="1"
                Padding="32 12"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0 1 0 0"
                Background="{ThemeResource LayerFillColorDefaultBrush}">
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center" HorizontalAlignment="Right">
                <Button x:Uid="ConfigSaveBtn"
                        Command="{x:Bind ViewModel.SaveCommand}"
                        Style="{StaticResource AccentButtonStyle}"/>
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

    </Grid>
</Page>
