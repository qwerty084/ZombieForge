<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ZombieForge.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:ZombieForge.Models">

    <StackPanel Padding="32 24" Spacing="16">
        <TextBlock x:Uid="SettingsTitle" Style="{StaticResource TitleTextBlockStyle}"/>

        <!-- Language -->
        <StackPanel Spacing="8">
            <TextBlock x:Uid="LanguageLabel" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <ComboBox ItemsSource="{x:Bind ViewModel.Languages}"
                      SelectedItem="{x:Bind ViewModel.SelectedLanguage, Mode=TwoWay}"
                      MinWidth="220">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="models:LanguageOption">
                        <TextBlock Text="{x:Bind DisplayName}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <InfoBar x:Uid="LanguageRestartNotice"
                     IsOpen="{x:Bind ViewModel.RestartRequired, Mode=OneWay}"
                     IsClosable="False"
                     Severity="Informational"/>
        </StackPanel>
    </StackPanel>
</Page>
