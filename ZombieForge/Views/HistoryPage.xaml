<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ZombieForge.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ZombieForge.Views"
    xmlns:models="using:ZombieForge.Models">

    <Grid Padding="32 24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Uid="HistoryTitle" Style="{StaticResource TitleTextBlockStyle}"/>

        <!-- Search and Filter Bar -->
        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MaxWidth="320"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Uid="HistorySearchBox"
                     Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Grid.Column="0"/>

            <ComboBox x:Uid="HistoryMapFilter"
                      Grid.Column="1"
                      MinWidth="160"
                      ItemsSource="{x:Bind ViewModel.MapFilterOptions, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedMapFilter, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <TextBlock Text="{x:Bind local:HistoryPage.FormatMapFilterOption((x:String))}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Grid>

        <!-- Session List -->
        <ListView Grid.Row="2"
                  ItemsSource="{x:Bind ViewModel.FilteredEntries, Mode=OneWay}"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:GameHistoryEntry">
                    <Grid Padding="12" ColumnSpacing="16" RowSpacing="4"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="1"
                          CornerRadius="{StaticResource ControlCornerRadius}"
                          Margin="0 4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Map name + running badge -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{x:Bind MapName}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <Border Visibility="{x:Bind IsRunning, Converter={StaticResource BoolToVisibility}}"
                                    Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                                    CornerRadius="4"
                                    Padding="8 2">
                                <TextBlock x:Uid="HistoryRunningBadge"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                            </Border>
                        </StackPanel>

                        <!-- Date/time -->
                        <TextBlock Grid.Row="1"
                                   Text="{x:Bind local:HistoryPage.FormatSessionDate(StartedAtUtc)}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <!-- Round info -->
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{x:Bind local:HistoryPage.FormatRound(FinalRound)}"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   HorizontalAlignment="Right"/>

                        <!-- Stats row -->
                        <StackPanel Grid.Row="2" Grid.ColumnSpan="2"
                                    Orientation="Horizontal" Spacing="20"
                                    Margin="0 4 0 0">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock x:Uid="HistoryStatKills"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind Kills}" Style="{StaticResource CaptionTextBlockStyle}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock x:Uid="HistoryStatDowns"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind Downs}" Style="{StaticResource CaptionTextBlockStyle}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock x:Uid="HistoryStatHeadshots"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind Headshots}" Style="{StaticResource CaptionTextBlockStyle}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock x:Uid="HistoryStatPoints"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind Points}" Style="{StaticResource CaptionTextBlockStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
